# ============================================================
# VitalSync - Variables d'environnement (EXEMPLE)
# ============================================================
# Copiez ce fichier en .env et remplacez les valeurs
# Ne commitez JAMAIS le fichier .env contenant les vraies valeurs
# ============================================================

# PostgreSQL - Identifiants de la base de données
POSTGRES_DB=vitalsync_db
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_secure_password_here

# Node.js - Environnement d'exécution
NODE_ENV=production
